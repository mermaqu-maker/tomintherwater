# Supabase — 프로젝트 생성 후 채우기 (docs/04 §5)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server Action 전용 (후기·댓글 쓰기, 캡차 검증 후) — 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# 배포 URL (배포 후 실제 도메인) — sitemap/OG/재설정 리다이렉트 기준
NEXT_PUBLIC_SITE_URL=

# 카카오톡 채널 (pf.kakao.com/_xxxx) — 실제 URL 확보 시 교체
NEXT_PUBLIC_KAKAO_CHANNEL_URL=

# Cloudflare Turnstile (후기·댓글 스팸 방지) — M4에서 사용
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
